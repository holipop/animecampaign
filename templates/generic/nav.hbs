<section class="Navigation">

    <div class="Navigation__Tabs tabs">
        {{#each tabs as |tab id|}}
            {{#if (gte @root.permission tab.permission)}}
                <button class="ACButton ACButton--Tab {{tab.css}}" type="button" data-action="tab" data-tab="{{tab.id}}" data-group="{{tab.group}}" style="color: {{@root.palette.secondary}}; border-color: {{@root.palette.secondary}};">
                    <span class="ACButton__Icon MSO">{{tab.icon}}</span>
                </button>
            {{/if}}
        {{/each}}
    </div>

    <span class="Navigation__TabName">
        {{#each tabs as |tab id|}}
            {{#if (gte @root.permission tab.permission)}}
                <span class="Navigation__TabNameContent tab {{tab.css}}" data-tab="{{tab.id}}" data-group="{{tab.group}}">{{localize tab.label}}</span>
            {{/if}}
        {{/each}}
    </span>

</section>